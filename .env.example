# =============================================================================
# 1panel-ssl-from-asus-router
# 复制为 .env 后填写真实值：  cp .env.example .env
# 华硕路由 SSH 拉证书：
#   docker compose run --rm ssl-from-router
# 或与 1Panel 连续执行：  ./sync.sh
# =============================================================================

# SSH 登录用户名（常见为 admin）
ROUTER_USER=admin

# 路由器 LAN IP 或可解析主机名
ROUTER_IP=192.168.1.1

# SSH 端口（默认 22）
ROUTER_SSH_PORT=22

# 路由器 SSH 密码
ROUTER_PASSWORD=CHANGEME

# 路由器上私钥绝对路径（按固件/证书实际位置）
KEY_PATH_ON_ROUTER=/jffs/.le/example.domain/example.domain.key

# 路由器上证书绝对路径（fullchain 或单证书）
CERT_PATH_ON_ROUTER=/jffs/.le/example.domain/fullchain.pem

# =============================================================================
# 1Panel — 网站 → 证书上传（POST {ONEPANEL_BASE_URL}{ONEPANEL_API_PATH}）
# 开启 API，并把运行 Docker 的主机 IP 加入白名单
# =============================================================================

# 仅协议+主机+端口，无末尾 /，无浏览器安全入口路径；HTTPS 面板用 https://
ONEPANEL_BASE_URL=https://192.168.1.100:24077

# 面板 API 密钥
ONEPANEL_API_KEY=CHANGEME

# 接口路径（默认 v2）
# ONEPANEL_API_PATH=/api/v2/websites/ssl/upload

# 网站-证书列表中已有条目 ID（覆盖）；新建填 0
ONEPANEL_SSL_ID=0

# 可选说明
# ONEPANEL_SSL_DESCRIPTION=

# 容器内 PEM 路径（一般不用改）
# ONEPANEL_KEY_FILE=/ssl/key.pem
# ONEPANEL_CERT_FILE=/ssl/cert.pem

# 面板 HTTPS 为自签/不受信时设为 1
ONEPANEL_SKIP_TLS_VERIFY=0
